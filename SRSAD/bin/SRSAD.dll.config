  <!--
    Pour obtenir une description des modifications de web.config, voir http://go.microsoft.com/fwlink/?LinkId=235367.

    Les attributs suivants peuvent être définis dans la balise <httpRuntime>.
      <system.Web>
        <httpRuntime targetFramework="4.8" />
      </system.Web>
  -->
  <system.web>
    <httpRuntime maxRequestLength="1048576" executionTimeout="3600" requestValidationMode="2.0" requestLengthDiskThreshold="1048576" maxQueryStringLength="2097151" maxUrlLength="2097151"/>
    <compilation debug="true" targetFramework="4.8"/>
