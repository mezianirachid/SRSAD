    <globalization requestEncoding="utf-8" responseEncoding="utf-8" culture="fr-CA" uiCulture="fr-CA"/>
    <!-- 
    <globalization uiCulture="fr-FR" culture="fr-FR" enableClientBasedCulture="true"/>
  -->
    <caching>
      <outputCacheSettings>
