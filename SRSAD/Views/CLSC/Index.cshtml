@model IEnumerable<SRSAD.Models.CLSC>

@{
    ViewBag.Title = "Gestion des CLSC";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h2>
                Gestion des CLSC
                <small class="pull-right">
                    @Html.ActionLink("Ajouter un CLSC", "Create", null, new { @class = "btn btn-success" })
                </small>
            </h2>
            <hr />
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            @TempData["Error"]
        </div>
    }

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">Recherche</h3>
                </div>
                <div class="panel-body">
                    @using (Html.BeginForm("Index", "CLSC", FormMethod.Get, new { @class = "form-inline" }))
                    {
                        <div class="form-group">
                            @Html.TextBox("searchNom", Request.QueryString["searchNom"], new { @class = "form-control", placeholder = "Nom du CLSC" })
                        </div>
                        <div class="form-group">
                            @Html.TextBox("searchCode", Request.QueryString["searchCode"], new { @class = "form-control", placeholder = "Code" })
                        </div>
                        <div class="checkbox">
                            <label>
                                @Html.CheckBox("actifUniquement", Request.QueryString["actifUniquement"] != "False")
                                Actifs uniquement
                            </label>
                        </div>
                        <button type="submit" class="btn btn-primary">Rechercher</button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">Liste des CLSC (@Model.Count())</h3>
                </div>
                <div class="panel-body">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>@Html.DisplayNameFor(m => m.CodeCLSC)</th>
                                <th>@Html.DisplayNameFor(m => m.NomCLSC)</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>@item.CodeCLSC</strong></td>
                                    <td>@item.NomCLSC</td>
                                    <td>
                                        @if (item.EstActif)
                                        {
                                            <span class="label label-success">Actif</span>
                                        }
                                        else
                                        {
                                            <span class="label label-default">Inactif</span>
                                        }
                                    </td>
                                    <td>
                                        @Html.ActionLink("Détails", "Details", new { id = item.CLSCID }, new { @class = "btn btn-xs btn-info" })
                                        @Html.ActionLink("Modifier", "Edit", new { id = item.CLSCID }, new { @class = "btn btn-xs btn-warning" })
                                        @using (Html.BeginForm("Delete", "CLSC", new { id = item.CLSCID }, FormMethod.Post, new { style = "display:inline", onsubmit = "return confirm('Supprimer ce CLSC ?');" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-xs btn-danger">Supprimer</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>