@model SRSAD.Models.CLSC

@{
    ViewBag.Title = "Créer un CLSC";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h2>
                Créer un CLSC
                <small class="pull-right">
                    @Html.ActionLink("Retour à la liste", "Index", null, new { @class = "btn btn-default" })
                </small>
            </h2>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 col-md-offset-3">
            <div class="panel panel-primary">
                <div class="panel-heading">
                    <h3 class="panel-title">Informations du CLSC</h3>
                </div>
                <div class="panel-body">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="form-group">
                            @Html.LabelFor(model => model.CodeCLSC, "Code *")
                            @Html.EditorFor(model => model.CodeCLSC, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                            @Html.ValidationMessageFor(model => model.CodeCLSC, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(model => model.NomCLSC, "Nom *")
                            @Html.EditorFor(model => model.NomCLSC, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                            @Html.ValidationMessageFor(model => model.NomCLSC, "", new { @class = "text-danger" })
                        </div>

                        <div class="checkbox">
                            <label>
                                @Html.CheckBoxFor(model => model.EstActif)
                                Actif
                            </label>
                        </div>

                        <hr />
                        <div class="form-group">
                            <button type="submit" class="btn btn-primary">
                                <span class="glyphicon glyphicon-save"></span> Créer
                            </button>
                            @Html.ActionLink("Annuler", "Index", null, new { @class = "btn btn-default" })
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>