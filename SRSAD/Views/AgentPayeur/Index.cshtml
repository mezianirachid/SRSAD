@model IEnumerable<SRSAD.Models.AgentsPayeurs>

@{
    ViewBag.Title = "Agents payeurs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h2>
                Gestion des agents payeurs
                <small class="pull-right">
                    @Html.ActionLink("Ajouter un agent payeur", "Create", null, new { @class = "btn btn-success" })
                    <button type="button" class="btn btn-info" onclick="exportToExcel()">
                        <span class="glyphicon glyphicon-export"></span> Exporter
                    </button>
                    <button type="button" class="btn btn-default" onclick="window.print()">
                        <span class="glyphicon glyphicon-print"></span> Imprimer
                    </button>
                </small>
            </h2>
            <hr />
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade in">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            <span class="glyphicon glyphicon-ok-sign"></span> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade in">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            <span class="glyphicon glyphicon-exclamation-sign"></span> @TempData["Error"]
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade in">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            <span class="glyphicon glyphicon-warning-sign"></span> @TempData["Warning"]
        </div>
    }

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">Recherche avancée</h3>
                </div>
                <div class="panel-body">
                    @using (Html.BeginForm("Index", "AgentPayeur", FormMethod.Get, new { @class = "form-horizontal" }))
                    {
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label class="col-sm-4 control-label">Code</label>
                                    <div class="col-sm-8">
                                        @Html.TextBox("searchCode", Request.QueryString["searchCode"], new { @class = "form-control input-sm", placeholder = "Code agent" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label class="col-sm-4 control-label">Code interne</label>
                                    <div class="col-sm-8">
                                        @Html.TextBox("searchAgentPayeurCode", Request.QueryString["searchAgentPayeurCode"], new { @class = "form-control input-sm", placeholder = "Code interne" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label class="col-sm-4 control-label">Nom</label>
                                    <div class="col-sm-8">
                                        @Html.TextBox("searchNom", Request.QueryString["searchNom"], new { @class = "form-control input-sm", placeholder = "Nom" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label class="col-sm-4 control-label">Type</label>
                                    <div class="col-sm-8">
                                        @Html.DropDownList("typeFinancementID", (SelectList)ViewBag.TypeFinancementList, "Tous", new { @class = "form-control input-sm" })
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="checkbox">
                                    <label>
                                        @Html.CheckBox("actifUniquement", Request.QueryString["actifUniquement"] != "False")
                                        <strong>Actifs uniquement</strong>
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6 text-right">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <span class="glyphicon glyphicon-search"></span> Rechercher
                                </button>
                                @Html.ActionLink("Réinitialiser", "Index", null, new { @class = "btn btn-default btn-sm" })
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">
                        Liste des agents payeurs
                        <span class="badge pull-right">@Model.Count() agent(s)</span>
                    </h3>
                </div>
                <div class="panel-body" style="overflow-x: auto;">
                    <table class="table table-striped table-hover table-condensed" id="agentsTable">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Code interne</th>
                                <th>Nom</th>
                                <th>Type financement</th>
                                <th>Description</th>
                                <th>Contact</th>
                                <th>Téléphone</th>
                                <th>Statut</th>
                                <th>Patients</th>
                                <th>Commandes</th>
                                <th>Créé le</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="@(item.EstActif ? "" : "text-muted")">
                                    <td><strong>@item.AgentPayeurCode</strong></td>
                                    <td>@item.AgentPayeurCode</td>
                                    <td>@item.Nom</td>
                                    <td>
                                        @if (item.TypesFinancementRef != null)
                                        {
                                            <span class="label label-primary">@item.TypesFinancementRef.TypeFinancementCode</span>
                                            <br />
                                            <small>@item.TypesFinancementRef.DESCRIPTION</small>
                                        }
                                        else
                                        {
                                            <span class="label label-default">Non défini</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            <span title="@item.Description">@(item.Description.Length > 30 ? item.Description.Substring(0, 30) + "..." : item.Description)</span>
                                        }
                                    </td>
                                    <td>@item.Contact</td>
                                    <td>@item.Telephone</td>
                                    <td>
                                        @if (item.EstActif)
                                        {
                                            <span class="label label-success">Actif</span>
                                        }
                                        else
                                        {
                                            <span class="label label-default">Inactif</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @{
                                            var nbPatients = ViewBag.StatistiquesPatients != null ?
                                                ((Dictionary<int, int>)ViewBag.StatistiquesPatients).ContainsKey(item.AgentPayeurID) ?
                                                ((Dictionary<int, int>)ViewBag.StatistiquesPatients)[item.AgentPayeurID] : 0 : 0;
                                        }
                                        <span class="badge @(nbPatients > 0 ? "badge-success" : "")">@nbPatients</span>
                                    </td>
                                    <td class="text-center">
                                        @{
                                            var nbCommandes = ViewBag.StatistiquesCommandes != null ?
                                                ((Dictionary<int, int>)ViewBag.StatistiquesCommandes).ContainsKey(item.AgentPayeurID) ?
                                                ((Dictionary<int, int>)ViewBag.StatistiquesCommandes)[item.AgentPayeurID] : 0 : 0;
                                        }
                                        <span class="badge @(nbCommandes > 0 ? "badge-info" : "")">@nbCommandes</span>
                                    </td>
                                    <td>
                                        @if (item.DateCreation.HasValue)
                                        {
                                            @item.DateCreation.Value.ToString("yyyy-MM-dd")
                                            <br />
                                            <small class="text-muted">@item.UtilisateurCreation</small>
                                        }
                                    </td>
                                    <td class="text-center" style="min-width: 200px;">
                                        <div class="btn-group btn-group-xs" role="group">
                                            @Html.ActionLink("Détails", "Details", new { id = item.AgentPayeurID }, new { @class = "btn btn-info", title = "Voir les détails" })
                                            @Html.ActionLink("Modifier", "Edit", new { id = item.AgentPayeurID }, new { @class = "btn btn-warning", title = "Modifier" })

                                            @if (item.EstActif)
                                            {
                                                using (Html.BeginForm("Desactiver", "AgentPayeur", new { id = item.AgentPayeurID }, FormMethod.Post, new { style = "display:inline", onsubmit = "return confirm('Désactiver cet agent payeur ? Les patients et commandes existants ne seront pas affectés.');" }))
                                                {
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-default" title="Désactiver">
                                                        <span class="glyphicon glyphicon-ban-circle"></span>
                                                    </button>
                                                }
                                            }
                                            else
                                            {
                                                using (Html.BeginForm("Activer", "AgentPayeur", new { id = item.AgentPayeurID }, FormMethod.Post, new { style = "display:inline", onsubmit = "return confirm('Activer cet agent payeur ?');" }))
                                                {
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-success" title="Activer">
                                                        <span class="glyphicon glyphicon-ok-circle"></span>
                                                    </button>
                                                }
                                            }

                                            @using (Html.BeginForm("Delete", "AgentPayeur", new { id = item.AgentPayeurID }, FormMethod.Post, new { style = "display:inline", onsubmit = "return confirm('Êtes-vous sûr de vouloir supprimer définitivement cet agent payeur ? Cette action est irréversible.');" }))
                                            {
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-danger" title="Supprimer définitivement">
                                                    <span class="glyphicon glyphicon-trash"></span>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    <small class="text-muted">
                        <span class="glyphicon glyphicon-info-sign"></span>
                        Total: @Model.Count() agents payeurs |
                        Actifs: @Model.Count(a => a.EstActif) |
                        Inactifs: @Model.Count(a => !a.EstActif)
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .badge-success {
        background-color: #5cb85c;
    }

    .badge-info {
        background-color: #5bc0de;
    }

    .table > tbody > tr > td {
        vertical-align: middle;
    }

    .btn-group-xs > .btn {
        padding: 3px 6px;
        font-size: 11px;
    }
</style>

@section scripts {
    <script src="https://cdn.datatables.net/1.10.20/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.10.20/js/dataTables.bootstrap.min.js"></script>

    <script>
        $(document).ready(function () {
            // Initialiser DataTable avec toutes les colonnes
            var table = $('#agentsTable').DataTable({
                "paging": true,
                "pageLength": 25,
                "lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "Tous"]],
                "ordering": true,
                "info": true,
                "searching": true,
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.20/i18n/French.json"
                },
                "columnDefs": [
                    { "orderable": false, "targets": 11 }, // Désactiver le tri sur la colonne actions
                    { "type": "date", "targets": 10 } // Tri par date
                ],
                "order": [[2, "asc"]] // Tri par défaut sur le nom
            });

            // Filtre personnalisé par type de financement
            $('#typeFinancementID').on('change', function () {
                var val = $.fn.dataTable.util.escapeRegex($(this).val());
                if (val === "") {
                    table.column(3).search("").draw();
                } else {
                    table.column(3).search(val, true, false).draw();
                }
            });
        });

        function exportToExcel() {
            // Version améliorée de l'export Excel avec toutes les colonnes
            var table = document.getElementById('agentsTable');
            var rows = table.querySelectorAll('tr');
            var csv = [];

            // Entête avec toutes les colonnes
            var headers = [
                'Code', 'Code interne', 'Nom', 'Type financement',
                'Description', 'Contact', 'Téléphone', 'Statut',
                'Nb Patients', 'Nb Commandes', 'Date création', 'Créé par'
            ];
            csv.push(headers.join(';'));

            // Données
            for (var i = 1; i < rows.length; i++) { // Commencer à 1 pour ignorer l'entête du tableau
                var row = rows[i];
                var cols = row.querySelectorAll('td');

                if (cols.length > 0) {
                    var rowData = [];

                    // Code
                    rowData.push('"' + (cols[0].innerText || '').trim() + '"');
                    // Code interne
                    rowData.push('"' + (cols[1].innerText || '').trim() + '"');
                    // Nom
                    rowData.push('"' + (cols[2].innerText || '').trim() + '"');
                    // Type financement
                    rowData.push('"' + (cols[3].innerText || '').replace(/\n/g, ' ').trim() + '"');
                    // Description
                    rowData.push('"' + (cols[4].innerText || '').trim() + '"');
                    // Contact
                    rowData.push('"' + (cols[5].innerText || '').trim() + '"');
                    // Téléphone
                    rowData.push('"' + (cols[6].innerText || '').trim() + '"');
                    // Statut
                    rowData.push('"' + (cols[7].innerText || '').trim() + '"');
                    // Nb Patients
                    rowData.push('"' + (cols[8].innerText || '0').trim() + '"');
                    // Nb Commandes
                    rowData.push('"' + (cols[9].innerText || '0').trim() + '"');
                    // Date création
                    rowData.push('"' + (cols[10].innerText || '').replace(/\n/g, ' ').trim() + '"');

                    csv.push(rowData.join(';'));
                }
            }

            // Télécharger le fichier CSV
            var blob = new Blob(["\uFEFF" + csv.join('\n')], { type: 'text/csv;charset=utf-8;' }); // \uFEFF pour UTF-8 avec BOM
            var link = document.createElement("a");
            var url = URL.createObjectURL(blob);
            link.href = url;
            link.download = "agents_payeurs_" + new Date().toISOString().slice(0, 10) + ".csv";
            link.click();
            URL.revokeObjectURL(url);
        }
    </script>
}

@* Styles supplémentaires pour DataTables *@
<link rel="stylesheet" href="https://cdn.datatables.net/1.10.20/css/dataTables.bootstrap.min.css" />