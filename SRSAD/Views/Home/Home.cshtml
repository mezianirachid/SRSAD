@{
    ViewBag.Title = "Accueil - Gestion des Locaux Hospitaliers";
}

<div class="container-fluid" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh;">
    <!-- Particules d'arrière-plan -->
    

    <div class="row w-100">
        <div class="col-12 text-center text-white">
            <!-- Section BIENVENUE en haut de la page -->
            <div class="welcome-top pt-5">
                <div class="icon-container mb-4">
                    <div class="bg-white bg-opacity-20 rounded-circle d-inline-flex align-items-center justify-content-center p-4 floating"
                         style="backdrop-filter: blur(10px); width: 150px; height: 50px;">
                        <i class="fas fa-hospital-symbol fa-4x text-white"></i>
                    </div>
                </div>

                <h1 class="display-1 fw-bold mb-4" style="text-shadow: 3px 3px 6px rgba(0,0,0,0.3);">
                    Bienvenue sur votre Plateforme de Gestion
                </h1>

                <p class="lead fs-2 mb-4 opacity-90" style="text-shadow: 1px 1px 2px rgba(0,0,0,0.2);">
                    Gestion Intelligente des Locaux Hospitaliers
                </p>

                <p class="fs-3 opacity-75 mb-5">
                    Optimisez l'utilisation de vos espaces médicaux avec notre plateforme innovante
                </p>

                <!-- Boutons d'action principaux -->
                <div class="d-flex justify-content-center gap-4 flex-wrap">
                    <button class="btn btn-light btn-lg px-5 py-3 fw-bold pulse" style="border-radius: 15px; font-size: 1.3rem;">
                        <i class="fas fa-play me-2"></i>Démarrer la Démo
                    </button>
                    <button class="btn btn-outline-light btn-lg px-5 py-3 fw-bold" style="border-radius: 15px; font-size: 1.3rem;">
                        <i class="fas fa-book me-2"></i>Voir la Documentation
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Styles pour le positionnement en haut -->
<style>
    /* Positionnement en haut */
    .welcome-top {
        padding-top: 5rem;
        padding-bottom: 3rem;
    }

    /* Animations */
    .floating {
        animation: floating 3s ease-in-out infinite;
    }

    @@keyframes floating {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-20px);
        }
    }

    .pulse {
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }

        100% {
            transform: scale(1);
        }
    }

    .display-1 {
        background: linear-gradient(45deg, #ffffff, #e3f2fd);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1.2;
    }

    .btn-light, .btn-outline-light {
        transition: all 0.3s ease;
    }

        .btn-light:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255,255,255,0.3);
        }

        .btn-outline-light:hover {
            background-color: rgba(255,255,255,0.1);
            transform: translateY(-2px);
        }

    /* Particules */
    #particles-js {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .welcome-top {
            padding-top: 3rem;
            padding-bottom: 2rem;
        }

        .display-1 {
            font-size: 3rem;
        }

        .lead.fs-2 {
            font-size: 1.5rem !important;
        }

        .fs-3 {
            font-size: 1.25rem !important;
        }

        .btn-lg {
            font-size: 1.1rem !important;
            padding: 12px 20px !important;
        }
    }

    @@media (max-width: 576px) {
        .welcome-top {
            padding-top: 2rem;
        }

        .display-1 {
            font-size: 2.5rem;
        }

        .d-flex.gap-4 {
            gap: 2rem !important;
            flex-direction: column;
            align-items: center;
        }

        .btn-lg {
            width: 250px;
            margin-bottom: 1rem;
        }
    }
</style>

<!-- Scripts -->
@section Scripts {
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- Particles.js -->
    <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>

    <script>
        $(document).ready(function () {
            // Initialisation des particules
            particlesJS('particles-js', {
                particles: {
                    number: { value: 40, density: { enable: true, value_area: 800 } },
                    color: { value: "#ffffff" },
                    opacity: { value: 0.3, random: true },
                    size: { value: 3, random: true },
                    line_linked: {
                        enable: true,
                        distance: 150,
                        color: "#ffffff",
                        opacity: 0.2,
                        width: 1
                    },
                    move: {
                        enable: true,
                        speed: 2,
                        direction: "none",
                        random: true,
                        out_mode: "out"
                    }
                },
                interactivity: {
                    detect_on: "canvas",
                    events: {
                        onhover: {
                            enable: true,
                            mode: "repulse"
                        },
                        onclick: {
                            enable: true,
                            mode: "push"
                        }
                    }
                }
            });

            // Clic sur les boutons
            $('.btn-light').on('click', function () {
                alert('Démo lancée ! Redirection vers la page de démonstration...');
            });

            $('.btn-outline-light').on('click', function () {
                alert('Ouverture de la documentation...');
            });
        });
    </script>
}