@model SRSAD.Models.TypesInfection

@{
    ViewBag.Title = "Modifier un type d'infection";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h2>
                Modifier - @Model.Libelle
                <small class="pull-right">
                    @Html.ActionLink("Retour à la liste", "Index", null, new { @class = "btn btn-default" })
                </small>
            </h2>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 col-md-offset-3">
            <div class="panel panel-warning">
                <div class="panel-heading">
                    <h3 class="panel-title">Modification du type d'infection</h3>
                </div>
                <div class="panel-body">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.TypeInfectionID)

                        <div class="form-group">
                            @Html.LabelFor(model => model.Code, "Code *")
                            @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                            @Html.ValidationMessageFor(model => model.Code, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(model => model.Libelle, "Libellé *")
                            @Html.EditorFor(model => model.Libelle, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                            @Html.ValidationMessageFor(model => model.Libelle, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(model => model.Categorie, "Catégorie")
                            @Html.DropDownListFor(model => model.Categorie,
                                new SelectList(new[] { "Bactérie", "Virus", "Champignon", "Parasite", "Autre" }, Model.Categorie),
                                "Sélectionnez",
                                new { @class = "form-control" })
                            @Html.ValidationMessageFor(model => model.Categorie, "", new { @class = "text-danger" })
                        </div>

                        <div class="checkbox">
                            <label>
                                @Html.CheckBoxFor(model => model.EstActif)
                                Actif
                            </label>
                        </div>

                        <hr />
                        <div class="form-group">
                            <button type="submit" class="btn btn-warning">
                                <span class="glyphicon glyphicon-save"></span> Enregistrer les modifications
                            </button>
                            @Html.ActionLink("Annuler", "Index", null, new { @class = "btn btn-default" })
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>