@model SRSAD.Models.ParticularitesUsagerRef

@{
    ViewBag.Title = "Ajouter une particularité";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h2>
                Ajouter une particularité
                <small class="pull-right">
                    @Html.ActionLink("Retour à la liste", "Index", null, new { @class = "btn btn-default" })
                </small>
            </h2>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 col-md-offset-3">
            <div class="panel panel-primary">
                <div class="panel-heading">
                    <h3 class="panel-title">Informations de la particularité</h3>
                </div>
                <div class="panel-body">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="form-group">
                            @Html.LabelFor(model => model.Code, "Code *")
                            @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                            @Html.ValidationMessageFor(model => model.Code, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(model => model.Libelle, "Libellé *")
                            @Html.EditorFor(model => model.Libelle, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                            @Html.ValidationMessageFor(model => model.Libelle, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(model => model.NiveauAlerte, "Niveau d'alerte *")
                            @Html.DropDownListFor(model => model.NiveauAlerte,
                                new SelectList(new[] {
                                    new { Value = 0, Text = "Info" },
                                    new { Value = 1, Text = "Alerte" },
                                    new { Value = 2, Text = "Critique" },
                                    new { Value = 3, Text = "Urgent" }
                                }, "Value", "Text"),
                                "Sélectionnez",
                                new { @class = "form-control" })
                            @Html.ValidationMessageFor(model => model.NiveauAlerte, "", new { @class = "text-danger" })
                        </div>

                        <div class="checkbox">
                            <label>
                                @Html.CheckBoxFor(model => model.EstActif)
                                Actif
                            </label>
                        </div>

                        <hr />
                        <div class="form-group">
                            <button type="submit" class="btn btn-primary">
                                <span class="glyphicon glyphicon-save"></span> Créer
                            </button>
                            @Html.ActionLink("Annuler", "Index", null, new { @class = "btn btn-default" })
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>