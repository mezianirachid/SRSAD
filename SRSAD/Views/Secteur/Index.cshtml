@model IEnumerable<SRSAD.Models.SecteursSRSAD>

@{
    ViewBag.Title = "Gestion des secteurs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h2>
                Gestion des secteurs
                <small class="pull-right">
                    @Html.ActionLink("Ajouter un secteur", "Create", null, new { @class = "btn btn-success" })
                </small>
            </h2>
            <hr />
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">Recherche</h3>
                </div>
                <div class="panel-body">
                    @using (Html.BeginForm("Index", "Secteur", FormMethod.Get, new { @class = "form-inline" }))
                    {
                        <div class="form-group">
                            @Html.TextBox("searchNom", Request.QueryString["searchNom"], new { @class = "form-control", placeholder = "Nom du secteur" })
                        </div>
                        <div class="form-group">
                            @Html.TextBox("searchCode", Request.QueryString["searchCode"], new { @class = "form-control", placeholder = "Code" })
                        </div>
                        <div class="checkbox">
                            <label>
                                @Html.CheckBox("actifUniquement", Request.QueryString["actifUniquement"] != "False")
                                Actifs uniquement
                            </label>
                        </div>
                        <button type="submit" class="btn btn-primary">Rechercher</button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">Liste des secteurs (@Model.Count())</h3>
                </div>
                <div class="panel-body">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Nom</th>
                                <th>Codes postaux</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>@item.Code</strong></td>
                                    <td>@item.Nom</td>
                                    <td>
                                        <span class="badge">@(item.CodesPostauxSecteur?.Count() ?? 0)</span>
                                        @Html.ActionLink("Gérer", "CodesPostaux", new { id = item.SecteurID }, new { @class = "btn btn-xs btn-default" })
                                    </td>
                                    <td>
                                        @if (item.EstActif)
                                        {
                                            <span class="label label-success">Actif</span>
                                        }
                                        else
                                        {
                                            <span class="label label-default">Inactif</span>
                                        }
                                    </td>
                                    <td>
                                        @Html.ActionLink("Détails", "Details", new { id = item.SecteurID }, new { @class = "btn btn-xs btn-info" })
                                        @Html.ActionLink("Modifier", "Edit", new { id = item.SecteurID }, new { @class = "btn btn-xs btn-warning" })
                                        @using (Html.BeginForm("Delete", "Secteur", new { id = item.SecteurID }, FormMethod.Post, new { style = "display:inline", onsubmit = "return confirm('Supprimer ce secteur ?');" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-xs btn-danger">Supprimer</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>