<style>
    #header {
        margin-top:-40px;
        margin-left: 10px;
         margin-right: 10px;
         margin-bottom:10px;

        /*box-shadow: 0 4px 8px 0 #dddddd;*/
    }

    #header .logo {
        float: left;
        padding: 0 20px 0 0;
        background: #ffffff; 
        z-index: 99999;
        width: 230px;
        height: 90px;
    }

    #header .separator {
        width: 100%; 
        height: 64px;
    }

    #header .menu {
        background: #003399; 
        padding-left: 230px;
        width: 100%;   
    }

    #header .menu a {
        color: white;
        text-decoration: none;
        display: inline-block;
        margin: 4px 0px 4px 20px;
        font-size: 1.2rem;
    }

    #env {
        font-size: 16px;
        font-weight: bold;
        width: 120px;
        height: 30px;
        color: #eee;
        background-color: #009900;
        position: fixed;
        top: 0;
        left: 50%;
        margin-left: -60px;
        z-index: 999;
        text-align: center;
        vertical-align: middle;
        padding-top: 4px;
        border-radius: 0 0 10px 10px;
    }

    #envDev {
        float: left;
        writing-mode: vertical-rl;
        text-orientation: mixed;
        background-color: #00bb00;
        height: 90px;
        padding: 5px 0px;
        font-weight: bold;
    }
</style>



<div class="container"; style="padding-top:0; margin-top:0">
    <div id="header" class="container-fluid"> 
        <div class="logo">
            <img id="logo" src="~/Content/Images/CIUSSS_Est_Montreal_logo.png" alt="Accueil" />
        </div>
        <div class="separator">
        </div>
        <div class="menu hidden-xs">           
            @*@Html.ActionLink("Accueil", "", "")*@
            <a href="#"></a>
        </div>
    </div> 
</div>