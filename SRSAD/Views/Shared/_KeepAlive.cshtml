<!--Start Show Session Expire Warning Popup here -->
<body id="app">
    <div class="modal fade" id="session-expire-warning-modal" aria-hidden="true" data-keyboard="false" data-backdrop="static" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title">Session bientôt expirée.</h4>
                </div>
                <div class="modal-body">
                    Vous serez bientôt déconnecté en raison d'une longue inactivité. <br />
                    Votre session sera expirée dans <span id="seconds-timer"></span> secondes. <br />
                    Cliquez sur <span style="color:darkseagreen">«Prolonger votre session»</span> pour rester connecté, ou sur <span style="color: orangered"> «Quitter»</span> pour vous déconnecter.  <br />
                </div>
                <div class="modal-footer">
                    <button id="btnOk" type="button" class="btn btn-success">Prolonger votre session</button>
                    <button id="btnLogoutNow" type="button" class="btn btn-danger">Quitter</button>
                </div>
            </div>
        </div>
    </div>
    <div id="demo2" class="hidden">4500</div>
</body>
    <script>
        var const2 = 4500; // deconnecter apres 75 minutes (75 * 60 = 4500)
        var time2 = 4500; // deconnecter apres 75 minutes (75 * 60 = 4500)
        var saved_countdown2 = localStorage.getItem('saved_countdown2');

        //$(window).on('load', function () {
        //    document.getElementById("demo2").innerHTML = const2;
        //})

        //localStorage.removeItem('saved_countdown2');

        if (saved_countdown2 == null) {
            // Set the time we're counting down to using the time allowed
            var new_countdown2 = new Date().getTime() + (time2 + 2) * 1000;

            time2 = new_countdown2;
            localStorage.setItem('saved_countdown2', new_countdown2);
        } else {
            time2 = saved_countdown2;
        }


        // Update the count down every 1 second
        var x2 = setInterval(() => {
            // Get today's date and time
            var now2 = new Date().getTime();

            // Find the distance between now and the allowed time
            //var distance1 = time1 - now2;
            var distance2 = time2 - now2;

            // Time counter
            //var counter1 = Math.floor(distance1 / 1000);
            var counter2 = Math.floor(distance2 / 1000);

            // Output the result in an element with id="demo2"
            document.getElementById("demo2").innerHTML = counter2;

            // If the count down is over, write some text
            if (counter2 <= 180) {
                clearInterval(x2);
                localStorage.removeItem('saved_countdown2');
                //deconnecter();
                javascript: document.getElementById('logoutForm').submit()
            }
        });



        // Timer coordonnateur en timer1 et timer2
        // On defnit dans ce timer un evenement sur la souris.
        var seconds = 0;

        setInterval(function () {
            document.addEventListener('mousemove', function () {
                //document.getElementById("demo2").innerHTML = time2
                var div2 = document.querySelector("#demo2");
                div2.innerText = const2;
                clearTimeout(x2);
                localStorage.removeItem('saved_countdown2');
            }, false);
        }, 1000);

        function deconnecter() {

            var timeout = 2; // 5 minutes
            var beattime = 1 * 60 * 1000; //timer to check activity ping 1 minutes
            var renew = 0;
            var hold = 0;
            var counter = 30; // Count down timer for Popup modal in seconds
            var sessoff = " javascript:document.getElementById('logoutForm').submit()"; //logout action url
            var sessurl = "../home/KeepSessionAlive";
            var hbeat;
            var abeat;
            var popTimer;
            $("#session-expire-warning-modal").modal('hide');
            ClientAlive = 0;
            CheckAlive();
            ActiveBeat();
            HeartBeat();
            $("#btnOk").click(function () {
                $("#session-expire-warning-modal").modal('hide');
                localStorage.removeItem('saved_countdown2');
                window.location.reload();
            });
            $("#btnLogoutNow").click(function () {
                $("#session-expire-warning-modal").modal('hide');
                //window.location = sessoff;
                localStorage.removeItem('saved_countdown1');
                localStorage.removeItem('saved_countdown2');
                var url = '@Url.Action("Login", "Account")';
                window.location.href = url;
            });
            function HeartBeat() {
                hbeat = setTimeout(function () {
                    if (!ClientAlive) {
                        renew = 0;
                        hold = 1;
                        countdownDisplay();
                        $("#session-expire-warning-modal").modal('show');
                        beep();
                        setTimeout(function () {
                            if (renew == 0) {
                                $("#session-expire-warning-modal").modal('hide');
                                window.location = sessoff;
                            }
                        }, counter * 1000);
                    }
                    else {
                        PingServer('ActBeatForced');
                    }
                }, timeout);
            }
            function ActiveBeat() {
                abeat = setTimeout(function () {
                    if (ClientAlive) {
                        PingServer('Abeat');
                    }
                    else {
                        clearTimeout(abeat);
                        beattimex = beattime / 1000;
                        ActiveBeat()
                    }
                }, beattime);
            }
            function PingServer(src) {

                $.ajax({
                    type: "POST",
                    url: sessurl,
                    success: function (data) {
                    },
                    error: function (data) {

                        console.log("Erreur:  " & keepSessionAliveUrl);
                    }
                });
                clearTimeout(abeat);
                beattimex = beattime / 1000;
                clearTimeout(hbeat);
                timeoutx = timeout / 1000;
                clearTimeout(popTimer);
                ClientAlive = 0;
                HeartBeat();
                ActiveBeat();
                CheckAlive();
                renew = 1;
            }
            function CheckAlive() {
                $("body").on("mousemove keydown", function () {
                    if (!hold) {
                        ClientAlive = 1;
                    }
                });
            }
            function countdownDisplay() {
                var dialogDisplaySeconds = counter;
                popTimer = setInterval(function () {
                    $('#seconds-timer').html(dialogDisplaySeconds);
                    dialogDisplaySeconds -= 1;
                }, 1000);
            };
            function beep() {
                var snd = new Audio("data:audio/wav;base64,");
                snd.play();
            }
        }
    </script>

    <script>
        var timeOut = null;
        var activityMade = function () {
            clearInterval(timeOut);
            timeOut = setInterval(function () {window.location.reload(); }, 120000);
        }
        var bindEvents = function () {
            var body = document.getElementById("app");
            body.addEventListener('click', activityMade);
            body.addEventListener('mousemove', activityMade);
            body.addEventListener('scroll', activityMade);
            activityMade();
        }
        bindEvents();
    </script>



