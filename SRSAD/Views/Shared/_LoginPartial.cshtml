@using Microsoft.AspNet.Identity

@if (Request.IsAuthenticated)
{
    using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm", @class = "navbar-right" }))
    {
        @Html.AntiForgeryToken()

        <ul class="nav navbar-nav navbar-right">
            <li>
                @Html.ActionLink("Bonjour " + User.Identity.GetUserName() + "!", "Profil", "Utilisateur", routeValues: null, htmlAttributes: new { title = "Mon profil" })
            </li>
            <li><a href="javascript:document.getElementById('logoutForm').submit()">Déconnexion</a></li>
        </ul>
    }
}
else
{
    <ul class="nav navbar-nav navbar-right">
        <li>@Html.ActionLink("Connexion", "Login", "Compte", routeValues: null, htmlAttributes: new { id = "loginLink" })</li>
    </ul>
}