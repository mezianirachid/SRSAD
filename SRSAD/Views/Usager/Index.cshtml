@model IEnumerable<SRSAD.ViewModels.UsagerListViewModel>

@{
    ViewBag.Title = "Liste des usagers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h2>
                Gestion des usagers
                <small class="pull-right">
                    @Html.ActionLink("Nouvel usager", "Create", null, new { @class = "btn btn-success" })
                </small>
            </h2>
            <hr />
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="row">
            <div class="col-md-12">
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert">&times;</button>
                    @TempData["Success"]
                </div>
            </div>
        </div>
    }

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">Recherche</h3>
                </div>
                <div class="panel-body">
                    @using (Html.BeginForm("Index", "Usager", FormMethod.Get, new { @class = "form-inline" }))
                    {
                        <div class="form-group">
                            @Html.TextBox("searchNom", Request.QueryString["searchNom"], new { @class = "form-control", placeholder = "Nom" })
                        </div>
                        <div class="form-group">
                            @Html.TextBox("searchPrenom", Request.QueryString["searchPrenom"], new { @class = "form-control", placeholder = "Prénom" })
                        </div>
                        <div class="form-group">
                            @Html.TextBox("searchIPM", Request.QueryString["searchIPM"], new { @class = "form-control", placeholder = "N° IPM" })
                        </div>
                        <div class="form-group">
                            @Html.DropDownList("secteurId", (SelectList)ViewBag.Secteurs, "Tous secteurs", new { @class = "form-control" })
                        </div>
                        <div class="form-group">
                            @Html.DropDownList("statutDossierId", (SelectList)ViewBag.Statuts, "Tous statuts", new { @class = "form-control" })
                        </div>
                        <button type="submit" class="btn btn-primary">Rechercher</button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">Liste des usagers (@Model.Count())</h3>
                </div>
                <div class="panel-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>N° SRSAD</th>
                                    <th>N° IPM</th>
                                    <th>Nom complet</th>
                                    <th>RAMQ</th>
                                    <th>Secteur</th>
                                    <th>Statut</th>
                                    <th>Adresse</th>
                                    <th>Téléphone</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td><strong>@item.NoDossierSRSAD</strong></td>
                                        <td>@item.NoDossierIPM</td>
                                        <td>@item.NomComplet</td>
                                        <td>@item.RAMQ</td>
                                        <td>@item.Secteur</td>
                                        <td>
                                            @if (item.StatutDossier == "Hospitalisé")
                                            {
                                                <span class="label label-warning">@item.StatutDossier</span>
                                            }
                                            else if (item.StatutDossier == "Radié")
                                            {
                                                <span class="label label-default">@item.StatutDossier</span>
                                            }
                                            else
                                            {
                                                <span class="label label-success">@item.StatutDossier</span>
                                            }
                                        </td>
                                        <td>@item.AdresseCourante</td>
                                        <td>@item.Telephone</td>
                                        <td>
                                            @Html.ActionLink("Détails", "Details", new { id = item.UsagerID }, new { @class = "btn btn-xs btn-info" })
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>