@model IEnumerable<SRSAD.ViewModels.ResultatRechercheEClinibaseViewModel>

@{
    ViewBag.Title = "Résultats de recherche E-Clinibase";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h2>
                Résultats de recherche
                <small class="pull-right">
                    @Html.ActionLink("Nouvelle recherche", "Create", null, new { @class = "btn btn-default" })
                </small>
            </h2>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-info">
                <div class="panel-heading">
                    <h3 class="panel-title">
                        <span class="glyphicon glyphicon-list"></span> @Model.Count() patient(s) trouvé(s) dans E-Clinibase
                    </h3>
                </div>
                <div class="panel-body">
                    <p>Sélectionnez le patient à importer :</p>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>N° IPM</th>
                                    <th>Nom complet</th>
                                    <th>Date naissance</th>
                                    <th>Âge</th>
                                    <th>RAMQ</th>
                                    <th>Sexe</th>
                                    <th>Adresse</th>
                                    <th>Téléphone</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td><strong>@item.NoIPM</strong></td>
                                        <td>@item.NomComplet</td>
                                        <td>@item.DateNaissance.ToShortDateString()</td>
                                        <td>@item.Age ans</td>
                                        <td>@item.RAMQ</td>
                                        <td>@item.Sexe</td>
                                        <td>@item.AdresseComplete</td>
                                        <td>@item.Telephone</td>
                                        <td>
                                            @Html.ActionLink("Importer", "Importer", new { ipm = item.NoIPM },
                                                new { @class = "btn btn-sm btn-success" })
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>