@model IEnumerable<SRSAD.Models.PeriodesFinancieresRef>

@{
    ViewBag.Title = "Périodes financières";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h2>
                Périodes financières
                <small class="pull-right">
                    @Html.ActionLink("Ajouter une période", "Create", null, new { @class = "btn btn-success" })
                </small>
            </h2>
            <hr />
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">Recherche</h3>
                </div>
                <div class="panel-body">
                    @using (Html.BeginForm("Index", "PeriodeFinanciere", FormMethod.Get))
                    {
                        <div class="form-group">
                            @Html.TextBox("searchCode", Request.QueryString["searchCode"], new { @class = "form-control", placeholder = "Code" })
                        </div>
                        <div class="checkbox">
                            <label>
                                @Html.CheckBox("activesUniquement", Request.QueryString["activesUniquement"] != "False")
                                Périodes actives uniquement
                            </label>
                        </div>
                        <button type="submit" class="btn btn-primary">Rechercher</button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Date début</th>
                        <th>Date fin</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.EstActive ? "success" : "")">
                            <td><strong>@item.Code</strong></td>
                            <td>@item.DateDebut.ToShortDateString()</td>
                            <td>@item.DateFin.ToShortDateString()</td>
                            <td>
                                @if (item.EstActive)
                                {
                                    <span class="label label-success">Active</span>
                                }
                                else
                                {
                                    <span class="label label-default">Inactive</span>
                                }
                            </td>
                            <td>
                                @Html.ActionLink("Détails", "Details", new { id = item.PeriodeFinID }, new { @class = "btn btn-xs btn-info" })
                                @Html.ActionLink("Modifier", "Edit", new { id = item.PeriodeFinID }, new { @class = "btn btn-xs btn-warning" })
                                @if (!item.EstActive)
                                {
                                    using (Html.BeginForm("Activer", "PeriodeFinanciere", new { id = item.PeriodeFinID }, FormMethod.Post, new { style = "display:inline" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-xs btn-success" onclick="return confirm('Activer cette période ?');">Activer</button>
                                    }
                                }
                                @using (Html.BeginForm("Delete", "PeriodeFinanciere", new { id = item.PeriodeFinID }, FormMethod.Post, new { style = "display:inline", onsubmit = "return confirm('Supprimer cette période ?');" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-xs btn-danger">Supprimer</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>